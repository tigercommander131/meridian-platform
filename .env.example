# Copy to .env for `docker compose up`. Change every secret before production.
POSTGRES_USER=parasol_dev
POSTGRES_PASSWORD=dev_password
POSTGRES_DB=parasol_ems

# Generate strong values, e.g.  openssl rand -hex 32
JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_too_in_production

# Public URL the browser uses to reach the backend API (baked into the frontend build).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Backend hardening (optional locally; set in production)
# DATABASE_SSL=true        # enable TLS to the DB (managed provider public endpoints)
# CORS_ORIGIN=https://your-frontend.up.railway.app
# PG_POOL_MAX=10           # max DB connections in the pool
